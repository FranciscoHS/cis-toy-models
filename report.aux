\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces One-hot responses overlaid for the $F=20, n=5$ $L^4$ model, one trace per input $e_j$, each shifted so the active feature is at offset $0$. The $20$ traces coincide at offset $0$ (all active-feature readouts $\approx \alpha \cdot n/F = 0.511$), and all cross-talk values stay within $\pm \alpha \cdot \mathrm  {Welch} = \pm 0.203$.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:overlay}{{2}{4}{One-hot responses overlaid for the $F=20, n=5$ $L^4$ model, one trace per input $e_j$, each shifted so the active feature is at offset $0$. The $20$ traces coincide at offset $0$ (all active-feature readouts $\approx \alpha \cdot n/F = 0.511$), and all cross-talk values stay within $\pm \alpha \cdot \mathrm {Welch} = \pm 0.203$}{figure.2}{}}
\@writefile{toc}{\contentsline {paragraph}{$L^4$ makes it optimal.}{4}{section*.4}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Not forced by geometry in our setup.}{4}{section*.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Single-feature response matrix $R$ for the $F=20$, $n=5$ $L^4$-trained model. Left: $R$ heatmap with features sorted by codeword. Middle: distribution of diagonal (red), same-codeword off-diagonal (orange, 4 entries) and different-codeword off-diagonal (blue, 376 entries). Dotted red and blue lines mark $\alpha \cdot n/F$ and $\pm \alpha \cdot \mathrm  {Welch}$ respectively. Right: singular values of $R$ on a log scale; the drop between index $5$ and $6$ is $8$ orders of magnitude.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:20f5n}{{3}{5}{Single-feature response matrix $R$ for the $F=20$, $n=5$ $L^4$-trained model. Left: $R$ heatmap with features sorted by codeword. Middle: distribution of diagonal (red), same-codeword off-diagonal (orange, 4 entries) and different-codeword off-diagonal (blue, 376 entries). Dotted red and blue lines mark $\alpha \cdot n/F$ and $\pm \alpha \cdot \mathrm {Welch}$ respectively. Right: singular values of $R$ on a log scale; the drop between index $5$ and $6$ is $8$ orders of magnitude}{figure.3}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3}Why a uniform-diagonal projection, specifically}{5}{section.3}\protected@file@percent }
\newlabel{eq:beta}{{3}{5}{Why a uniform-diagonal projection, specifically}{equation.3.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Summary of $L^4$-trained models. $\alpha $ is the scale factor in $R \approx \alpha P$, computed as $\mathrm  {mean}\,\mathrm  {diag}(R) \cdot F/n$. Frobenius ratio is $\|sR-I\|_F^2 \,/\, (F-n)$. Saturation of the rank-$n$ bound is essentially perfect everywhere; diagonal uniformity is high (the top-$n$ singular-value spread is small); Welch-bound prediction for the off-diagonal magnitudes matches observation to $\sim 10\%$ in the regime where features get unique codewords ($F \le 2^n - 1$).}}{6}{table.1}\protected@file@percent }
\newlabel{tab:scan}{{1}{6}{Summary of $L^4$-trained models. $\alpha $ is the scale factor in $R \approx \alpha P$, computed as $\mathrm {mean}\,\mathrm {diag}(R) \cdot F/n$. Frobenius ratio is $\|sR-I\|_F^2 \,/\, (F-n)$. Saturation of the rank-$n$ bound is essentially perfect everywhere; diagonal uniformity is high (the top-$n$ singular-value spread is small); Welch-bound prediction for the off-diagonal magnitudes matches observation to $\sim 10\%$ in the regime where features get unique codewords ($F \le 2^n - 1$)}{table.1}{}}
